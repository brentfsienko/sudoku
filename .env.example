# Liveblocks realtime (https://liveblocks.io/dashboard) — required for 2-player modes.
# Single-player works without this.
LIVEBLOCKS_SECRET_KEY=sk_dev_xxxxxxxxxxxxxxxxxxxxxxxx

# Canonical URL for link previews (optional; Vercel sets VERCEL_URL automatically).
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Supabase (https://supabase.com) — enables login + cross-device stats sync.
# Stats fall back to on-device localStorage when these are missing.
# Run supabase/trivia.sql in the SQL editor for today's-fact guess percentages.
# Project Settings → API Keys (use the publishable key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
